{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compileOnSave": true,
  "compilerOptions": {
    "outDir": "./dist",
    "sourceMap": true,
    "skipLibCheck": true,
    "noEmit": false,
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "inlineSources": true,
    "sourceRoot": "/",
    "isolatedModules": true,
    "typeRoots": ["./server/@types", "./node_modules/@types"]
  },
  "exclude": [
    "node_modules",
    "assets/**/*.js",
    "cypress-tests",
    "dist",
    "cypress.config.ts",
    "coverage",
    "esbuild",
    "oauth2-mock-server"
  ],
  "include": ["**/*.js", "**/*.ts", "oauth2-mock-server/jest.config.cjs"]
}
